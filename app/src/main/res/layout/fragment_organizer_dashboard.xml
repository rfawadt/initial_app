<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_lg">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title_large"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/organizer_view"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

            <ImageView
                android:id="@+id/iv_org_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_chip_selected"
                android:padding="8dp"
                android:src="@drawable/ic_profile"
                android:contentDescription="Profile" />
        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_stat_events"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title_large"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/events_stat"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:layout_marginHorizontal="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_stat_rsvps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="412"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title_large"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rsvps_stat"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:layout_marginStart="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_stat_views"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2K"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title_large"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/views_stat"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>
        </LinearLayout>

        <!-- Create Event Button -->
        <TextView
            android:id="@+id/btn_create_event"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="+ Create Event"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <!-- My Events -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:paddingHorizontal="@dimen/spacing_md"
            android:text="@string/my_events"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_subtitle"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_organizer_events"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_lg"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
