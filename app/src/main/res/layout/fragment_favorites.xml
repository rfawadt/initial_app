<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:orientation="vertical"
    android:paddingTop="@dimen/spacing_lg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/saved_events"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title_large"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_count"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_chip_selected"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_xs"
        android:text="@string/saved_events_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body" />

    <!-- Tab Bar: Saved / My RSVPs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:id="@+id/tab_saved"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_selected"
            android:gravity="center"
            android:text="Saved"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_rsvps"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="@string/my_rsvps"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

    <!-- Sub-tabs for RSVPs: Upcoming / Past (hidden by default) -->
    <LinearLayout
        android:id="@+id/layout_rsvp_subtabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md"
        android:visibility="gone">

        <TextView
            android:id="@+id/tab_upcoming"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:background="@drawable/bg_chip_selected"
            android:gravity="center"
            android:text="@string/upcoming"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_past"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="@string/past"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <!-- Events List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_events"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/spacing_md"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/no_saved_events"
        android:textColor="@color/text_tertiary"
        android:textSize="@dimen/text_subtitle"
        android:visibility="gone" />

</LinearLayout>
