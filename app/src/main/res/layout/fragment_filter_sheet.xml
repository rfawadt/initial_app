<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background_secondary"
    android:orientation="vertical"
    android:padding="@dimen/spacing_md">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filters"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_title"
        android:textStyle="bold" />

    <!-- Category Filter -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/filter_category"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_society"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_society" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_tech"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_tech" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_arts"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_arts" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_business"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_business" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_sports"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_sports" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Location Filter -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/filter_location"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_pdc"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PDC" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_sbasse"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SBASSE" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_sdsb"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SDSB" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_auditorium"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auditorium" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Type Filter -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/filter_type"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_online"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="@string/online"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <TextView
            android:id="@+id/btn_offline"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:text="@string/offline"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center"
            android:text="@string/clear_filters"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_body" />

        <TextView
            android:id="@+id/btn_apply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="@string/apply_filters"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
