<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_sm">

    <!-- Thumbnail -->
    <ImageView
        android:id="@+id/iv_thumb"
        android:layout_width="@dimen/event_thumb_size"
        android:layout_height="@dimen/event_thumb_size"
        android:background="@color/surface_elevated"
        android:scaleType="centerCrop"
        android:contentDescription="Event thumbnail" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/spacing_sm"
        android:orientation="vertical">

        <!-- Category + Organizer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_category_tag"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="ARTS"
                android:textColor="@color/text_on_primary"
                android:textSize="@dimen/text_tiny"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_organizer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Arts Council LUMS"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_tiny" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free"
                android:textColor="@color/free_tag"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Open Mic Night"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_subtitle"
            android:textStyle="bold" />

        <!-- Date & Venue -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_calendar"
                android:alpha="0.5"
                android:contentDescription="Date" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Sat, Mar 22 - 7:00 PM"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_tiny" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:src="@drawable/ic_location"
                android:alpha="0.5"
                android:contentDescription="Location" />

            <TextView
                android:id="@+id/tv_venue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="PDC Lawn"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_tiny" />
        </LinearLayout>
    </LinearLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_xs"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/btn_favorite"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_heart"
            android:contentDescription="Favorite" />

        <ImageView
            android:id="@+id/btn_share"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:src="@drawable/ic_share"
            android:alpha="0.5"
            android:contentDescription="Share" />
    </LinearLayout>
</LinearLayout>
