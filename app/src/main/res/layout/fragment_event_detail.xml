<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Event Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <ImageView
                android:id="@+id/iv_event_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/surface_card"
                android:contentDescription="Event image" />

            <!-- Category Tag + Share -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tv_category_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_category_tag"
                    android:paddingHorizontal="@dimen/spacing_sm"
                    android:paddingVertical="@dimen/spacing_xs"
                    android:text="SOCIETY"
                    android:textColor="@color/text_on_primary"
                    android:textSize="@dimen/text_tiny"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btn_share"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_card"
                    android:padding="8dp"
                    android:src="@drawable/ic_share"
                    android:contentDescription="Share" />
            </LinearLayout>
        </FrameLayout>

        <!-- Event Title -->
        <TextView
            android:id="@+id/tv_event_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_md"
            android:text="LUMS MUN 2025"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title_large"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_hosted_by"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_xs"
            android:text="Hosted by LUMUN Society"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <!-- Info Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md">

            <!-- Date Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_date_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fri, Mar"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tv_date_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Venue Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="@dimen/spacing_sm"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PDC"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/tv_venue_short"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lawn"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Seats Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tv_seats_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="53 left"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_people"
                    android:contentDescription="Capacity" />
            </LinearLayout>
        </LinearLayout>

        <!-- Seat Availability -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_people"
                    android:contentDescription="Seats" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="@string/seat_availability"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_seats_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="53 seats remaining"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_seats"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:max="100"
                android:progress="82"
                android:progressDrawable="@drawable/bg_seat_progress" />
        </LinearLayout>

        <!-- Date & Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_calendar"
                android:contentDescription="Date" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_full_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Friday, March 21, 2025"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8:00 AM - 6:00 PM"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_add_calendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="4dp"
                android:text="@string/add_to_calendar"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <!-- Venue Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Location" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_venue_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PDC Lawn, LUMS"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/tv_venue_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Opposite the SDSB building - 4 min walk"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_md"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:background="@color/divider" />

        <!-- About / Price / Get Tickets -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_subtitle"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_tiny" />

                    <TextView
                        android:id="@+id/tv_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PKR 500"
                        android:textColor="@color/accent"
                        android:textSize="@dimen/text_title"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_get_tickets"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/spacing_lg"
                    android:text="@string/get_tickets"
                    android:textColor="@color/text_on_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="UNSC, WHO, EU Parliament, and an ad hoc crisis committee."
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Updates Section -->
        <LinearLayout
            android:id="@+id/updates_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Updates"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_subtitle"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_updates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </LinearLayout>

        <!-- Bottom spacing -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_xl" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
